#!/bin/bash

# Launch the passed in URL as a web app in the default browser (or chromium if the default doesn't support --app).

browser=$(xdg-settings get default-web-browser)
extra_args=""

case $browser in
vivaldi*)
    # Force Vivaldi to use the Default profile.
    # We remove '-P' to avoid conflicts and stick to the standard chromium flag.
    extra_args='--profile-directory=Default'
    ;;
google-chrome* | brave-browser* | microsoft-edge* | opera* | helium*)
    # These browsers support --app natively; no extra args needed.
    ;;
*)
    # Fallback for unsupported browsers (like Firefox).
    browser="chromium.desktop"
    ;;
esac

# Find the executable path from the .desktop file and launch.
# We inject $extra_args (if any) before the --app flag.